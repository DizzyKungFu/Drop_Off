    task_schedule(further_info)
    task_schedule(update_waterfall)
    task_schedule(first_surprise)
    task_schedule(first_jeer)
    task_schedule(second_surprise)
    task_schedule(second_jeer)
    task_schedule(final_orders)
    task_schedule(ending_triggered)

    ## Docking stuff
    //shared/signal/docked if has_roles(ORIGIN_ID, "__player__")
    docker = to_object(ORIGIN_ID)
    print("Docking ship = ", docker.name)
    docked_at = to_object(SELECTED_ID).name
    if pickup == 0:
        if docked_at == "SB-8":
            await delay_sim(5)
            pickupship = docker
            print("Pickup ship = ", pickupship)
            for p in role("__player__"):
                if p is not None:
                    COMMS_SELECTED_ID = lf_Akana
                    COMMS_ORIGIN_ID = p
                    m = f"""All three commanders are now aboard your vessel and are eager to depart. It's your discretion about in which order to deliver them. But always be on the watch for enemy ships!"""
                    comms_receive(m, title="GO TO WORK", title_color="yellow")
                    sbs.play_audio_file(0, "../missions/Drop_Off/audio/Akana-02", 1.3, 1.0)
                    sbs.send_story_dialog(0, "GO TO WORK", m, get_face(lf_Akana), "#444")
            ## Add Nav Points for the drop off stations, so the players don't get lost
            nav_id_DS99 = sim.add_navpoint(-60000, 201, -63000, "DS-99", "#008000")
            nav_id_DS101 = sim.add_navpoint(61000, 51, 52000, "DS-101", "#008000")
            nav_id_DS106 = sim.add_navpoint(-67000, -199, 37000, "DS-106", "#008000")
            ## Move all the Commanders to first ship to dock with SB-8
            lifeform_transfer(lf_Evans, pickupship)
            lifeform_transfer(lf_Richards, pickupship)
            lifeform_transfer(lf_Thompson, pickupship)
            players = all_roles('__player__, tsn')
            update_Evans = to_object(lf_Evans.host).name
            update_Richards = to_object(lf_Richards.host).name
            update_Thompson = to_object(lf_Thompson.host).name
            comms_broadcast(players, f"""Current Cmdr Locations:""")
            comms_broadcast(players, f"""Cmdr Evans on {update_Evans}""")
            comms_broadcast(players, f"""Cmdr Richards on {update_Richards}""")
            comms_broadcast(players, f"""Cmdr Thompson on {update_Thompson}""")
            pickup = 1

    //shared/signal/docked if has_roles(ORIGIN_ID, "__player__")
    docker = to_object(ORIGIN_ID)
    print("Docking ship = ", docker.name)
    docked_at = to_object(SELECTED_ID).name
    if pickup == 1 and Evans == 0 and docker.id == pickupship.id:
        if docked_at == "DS-99":
            await delay_sim(3)
            print("Drop Off ship = ", docker.name)
            for p in role("__player__"):
                if p is not None:
                    COMMS_SELECTED_ID = station99
                    COMMS_ORIGIN_ID = p
                    m = f"""Thank you, Commander Evans is now aboard our station."""
                    comms_receive(m, title="GOOD WORK", title_color="yellow")
                    sbs.play_audio_file(0, "../missions/Drop_Off/audio/DS-99-01", 1.3, 1.0)
                    sbs.send_story_dialog(0, "GOOD WORK", m, get_face(station99), "#444")
            ## Move Evans aboard his station
            lifeform_transfer(lf_Evans, station99)
            players = all_roles('__player__, tsn')
            update_Evans = to_object(lf_Evans.host).name
            update_Richards = to_object(lf_Richards.host).name
            update_Thompson = to_object(lf_Thompson.host).name

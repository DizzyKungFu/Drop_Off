    ## Move player ship(s) close to SB-8
    player_list = role("__player__")
    c = 1
    for p in player_list:
        shared pickupship = to_object(p)
        eo = to_engine_object(p)
        eo.pos.x = 67000 + (c * 400)
        eo.pos.y = 0
        eo.pos.z = -69500 - (c * 400)
        c+=1

    ## Link sensors to the TSN ships (THIS IS THE WAY!)
    for p in role("__player__"):
        if p is not None:
            player_ship_id = to_id(p)
            link(player_ship_id, "extra_scan_source", role("tsn"))

    ## Link in the stations
    for p in role("__player__"):
        if p is not None:
            player_ship_id = to_id(p)
            link(player_ship_id, "extra_scan_source", role("station"))

    ## Link in the spy and nav asteroids
    for p in role("__player__"):
        if p is not None:
            player_ship_id = to_id(p)
            link(player_ship_id, "extra_scan_source", role("spyingeye"))

    ## Link in the Big Black Hole
    for p in role("__player__"):
        if p is not None:
            player_ship_id = to_id(p)
            link(player_ship_id, "extra_scan_source", role("bbh"))

    ## Mission variables
    shared pickup = 0
    shared Akana = 0
    shared Evans = 0
    shared Richards = 0
    shared Thompson = 0
    shared reminder = 0
    shared Skaraandecloak1 = 0
    shared Skaraanjeer1 = 0
    shared Richards_comms_update = 0
    shared Skaraandecloak2 = 0
    shared Skaraanjeer2 = 0
    shared Thompson_comms_update = 0
    shared finalinstructions = 0
    shared ending = 0

    ## Scheduled tasks
    await task_schedule(docking_standard_player_station)

====== first_surprise =======
    await delay_sim(2)

    if pickup == 0:
        jump first_surprise

    if Skaraandecloak1 == 0:
        for p in role("__player__"):
            #eo = to_engine_object(p)
            #print(f"Player Position: {int(eo.pos.x)}, {int(eo.pos.y)}, {int(eo.pos.z)}")
            distance106 = sbs.distance_id(pickupship.id, station106.id)
            #print("Distance to 106 = ", distance106)
            if distance106 <= 30000:
                Skaraandecloak1 = 1
        await delay_sim(2)
        jump first_surprise

    ## Skaraans "de-cloak" near DS-106 when players get near the station, but only with commanders!
    if Skaraandecloak1 == 1:
        Skaraanjeer1 = 1
        players = all_roles('__player__, tsn')
        shared skaraans01 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": -60000, "START_Y": -200, "START_Z": 44000})
        shared skaraans02 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": -62000, "START_Y": -200, "START_Z": 42000})
        if DIFFICULTY >= 6:
            shared skaraans11 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": -66000, "START_Y": -200, "START_Z": 45000})
        skaraans02list = linked_to(skaraans02, "ship_list")
        for baddie in skaraans02list:
            shared skaraan02a = to_object(baddie)
        set_face(skaraan02a.id, "ska #fff 0 0;ska #fff 0 3;ska #fff 1 4;ska #fff 1 1;")
        comms_broadcast(players, "HOSTILE SHIPS DE-CLOAKING NEAR DS-106", "red")
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = station106
                COMMS_ORIGIN_ID = p
                m = f"""MAYDAY! HOSTILE SHIPS HAVE DE-CLOAKED NEARBY! PLEASE HELP!"""
                comms_receive(m, title="ALERT", title_color="red")
                sbs.play_audio_file(0, "../missions/Drop_Off/audio/DS-106-02", 1.3, 1.0)
                sbs.send_story_dialog(0, "ALERT", m, get_face(station106), "#444")
        ->END


====== first_jeer =======
    await delay_sim(2)

    if Skaraanjeer1 == 0:
        jump first_jeer

    if Skaraanjeer1 == 1:
        await delay_sim(23)
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = skaraan02a
                COMMS_ORIGIN_ID = p
                m = f"""Attention, Terrans! Surrender the one you call Commander Richards. Our captain finds her comely and wishes to claim her as a war-concubine. Failure to comply will result in the destruction of your vessel and your base."""
                comms_receive(m, title="NOTARIZED STATEMENT OF WARLIKE INTENT", title_color="red")
                sbs.play_audio_file(0, "../missions/Drop_Off/audio/Skaraan-01", 1.3, 1.0)
                sbs.send_story_dialog(0, "NOTARIZED STATEMENT OF WARLIKE INTENT", m, get_face(skaraan02a), "#444")
        Richards_comms_update = 1
        ->END


====== second_surprise =======
    await delay_sim(2)

    if pickup == 0:
        jump second_surprise

    if Skaraandecloak2 == 0:
        for p in role("__player__"):
            #eo = to_engine_object(p)
            #print(f"Player Position: {int(eo.pos.x)}, {int(eo.pos.y)}, {int(eo.pos.z)}")
            distance101 = sbs.distance_id(pickupship.id, station101.id)
            #print("Distance to 101 = ", distance101)
            if distance101 <= 15000:
                Skaraandecloak2 = 1
        await delay_sim(2)
        jump second_surprise

    ## Skaraans "de-cloak" near DS-101 when players get near the station, but only with commanders!
    if Skaraandecloak2 == 1:
        Skaraanjeer2 = 1
        players = all_roles('__player__, tsn')
        shared skaraans03 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": 55000, "START_Y": 100, "START_Z": 52200})
        shared skaraans04 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": 54000, "START_Y": 100, "START_Z": 52000})
        if DIFFICULTY >= 6:
            shared skaraans12 = await prefab_spawn(prefab_fleet_raider, {"race": "skaraan", "fleet_difficulty": DIFFICULTY, "START_X": 56000, "START_Y": 100, "START_Z": 54000})
        skaraans03list = linked_to(skaraans03, "ship_list")
        for baddie in skaraans03list:
            shared skaraan03a = to_object(baddie)
        set_face(skaraan03a.id, "ska #fff 0 0;ska #fff 0 2;ska #fff 2 1;ska #fff 1 0;")
        comms_broadcast(players, "HOSTILE SHIPS DE-CLOAKING NEAR DS-101", "red")
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = station101
                COMMS_ORIGIN_ID = p
                comms_receive(f"""Just great, more enemy ships! We could really use some help here at DS-101!""", title="ALERT", title_color="red")
                sbs.play_audio_file(0, "../missions/Drop_Off/audio/DS-101-02", 1.3, 1.0)
        ->END


====== second_jeer =======
    await delay_sim(2)

    if Skaraanjeer2 == 0:
        jump second_jeer

    if Skaraanjeer2 == 1:
        await delay_sim(23)
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = skaraan03a
                COMMS_ORIGIN_ID = p
                m = f"""We are here for the life of this so-called 'Commander Thompson'. He is wanted for using disreputable war tactics against our species. Anyone who stands in the way of our revenge will be obliterated! This is your only warning."""
                comms_receive(m, title="NOTARIZED STATEMENT OF WARLIKE INTENT", title_color="red")
                sbs.play_audio_file(0, "../missions/Drop_Off/audio/Skaraan-02", 1.3, 1.0)
                sbs.send_story_dialog(0, "NOTARIZED STATEMENT OF WARLIKE INTENT", m, get_face(skaraan03a), "#444")
        Thompson_comms_update = 1
        ->END


====== final_orders =======
    await delay_sim(21)

    ## Count the enemies left
    left = role("raider")
    c = len(left)

    if finalinstructions == 0 and ending == 1:
        await delay_sim(23)
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = lf_Akana
                COMMS_ORIGIN_ID = p
                m = f"""Good work dropping off the commanders! Now just mop up any remaining hostiles in the sector and you can call it a day!"""
                comms_receive(m, title="MORE ORDERS", title_color="yellow")
                sbs.play_audio_file(0, "../missions/Drop_Off/audio/Akana-04", 1.3, 1.0)
                sbs.send_story_dialog(0, "MORE ORDERS", m, get_face(lf_Akana), "#444")
        finalinstructions = 1
        ->END

    await delay_sim(21)
    jump final_orders


====== ending_triggered =======
    await delay_sim(10)

    ## Count the enemies left
    left = role("raider")
    c = len(left)

    ## Count the players left
    playersships = role('__player__')

    ## See if all the commanders have been delivered
    if Evans == 1 and Richards == 1 and Thompson == 1:
        ending = 1

    ## End if the player ship carrying the commanders is destroyed
    if not object_exists(pickupship) and pickup == 1 and ending == 0:
        remove_role(left, "raider")
        START_TEXT = "Mission Failure!  Your ship carrying the commanders was destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    ## End if all the player ships are destroyed
    if len(playersships)==0:
        START_TEXT = "Mission Failure!  All the player ships have been destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    ## End if any base is destroyed
    if not object_exists(station8):
        remove_role(left, "raider")
        START_TEXT = "Mission Failure!  Starbase 8 was destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    if not object_exists(station99):
        remove_role(left, "raider")
        START_TEXT = "Mission Failure!  Deep Space 99 was destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    if not object_exists(station101):
        remove_role(left, "raider")
        START_TEXT = "Mission Failure!  Deep Space 101 was destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    if not object_exists(station106):
        remove_role(left, "raider")
        START_TEXT = "Mission Failure!  Deep Space 106 was destroyed!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    ## Time has run out
    if is_timer_set(SHARED, "time_limit") and is_timer_finished(SHARED, "time_limit"):
        # End attack
        remove_role(left, "raider")
        START_TEXT = "Mission time has run out!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/failure")
        signal_emit("show_game_results", None)
        ->END

    ## Victory by dropping off all commanders and eliminating all enemies
    if ending == 1 and c == 0:
        await delay_sim(5)
        START_TEXT = "Mission Success!  The commanders have been returned and all enemies are defeated!"
        GAME_STARTED = False
        GAME_ENDED = True
        sbs.play_music_file(0, "music/default/victory")
        signal_emit("show_game_results", None)
        ->END

    await delay_sim(10)
    jump ending_triggered

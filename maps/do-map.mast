                comms_receive(f"""Your orders are to dock with us and collect the three base commanders who've been attending a conference here, and then drop them off at their three respective bases located elsewhere in this sector.""", title="ORDERS", title_color="yellow")

    if pickup == 0 and Akana == 0:
        m = f"""This is Admiral Akana at Starbase 8 here. Your orders are to dock with us and collect the three base commanders who've been attending a conference here, and then drop them off at their three respective bases located elsewhere in this sector."""
        for p in role("__player__"):
            if p is not None:
                COMMS_SELECTED_ID = lf_Akana

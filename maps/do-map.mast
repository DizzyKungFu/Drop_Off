    //comms/internal/Commander_Evans
    + "Back" //comms
    + "Base Situation":
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "About my base"
                % It's very nice.
                % You might be surprised to learn that we have a lot of musicians on DS-99!
                % It's busy this time of year.
    +"How are your quarters?" if pickup == 1 and Evans == 0:
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "My quarters aboard your ship"
                % They are very nice, thank you.
                % Quite comfortable!
                % Your hospitality is just too generous!


    //comms/internal/Commander_Richards
    + "Back" //comms
    + "Base Situation":
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "About my base"
                % We're far out on our own in the boonies.
                % It's quiet. Too quiet!
                % I'm woried about it, honestly.
    +"How are your quarters?" if pickup == 1 and Richards == 0:
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "My quarters aboard your ship"
                % Better than my quarters aboard DS-106!
                % Luxurious!
                % Great, and everyone aboard has been so friendly!
    +"Why do the Skaraans want you?" if Richards_comms_update == 1:
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "The Skaraans"
                % Sigh, it's a long story.
                % That jerk never gives up!
                % Basically, this Skaraan captain fell in love with me early in my career and has been stalking me ever since!
                % I was on an undercover mission on Epsilon Ceti B-3 when I caught the eye of a partiularly infamous Skaraan.


    //comms/internal/Commander_Thompson
    + "Back" //comms
    + "Base Situation":
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "About my base"
                % I hate it!
                % It's a craphole!
                % Why do you care?
    +"How are your quarters?" if pickup == 1 and Thompson == 0:
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "My quarters aboard your ship"
                % Tiny and cramped.
                % They are unacceptable, but would it do any good to complain?
                % Just get me to DS-101 so I can get off this rust bucket.
    +"Why do the Skaraans want you?" if Thompson_comms_update == 1:
        with comms_override(COMMS_ORIGIN_ID, COMMS_LIFEFORM_ID):
            << "The Skaraans"
                % You better keep those bastards away from me!
                % I bested one of their War Corporation fleets and they've never let it go!
                % Ha! They're just envious that they didn't think of using a mine with a cloaking field.



    ## Start the game
    //signal/game_started 

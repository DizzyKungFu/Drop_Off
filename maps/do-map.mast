    terrain_setup_nebula(eventhorizon18, 1200, 0.7, "red")
    eventhorizon18.blob.set("unselectable", 1)

    ## Instead of random stations, create specific ones. These are all important to the story.
    ## Starting station
    shared station8 = to_object(npc_spawn(67000, 0, -67000, "SB-8", "tsn, station", "starbase_command", "behav_station"))
    ##set_face(station8.id, "ter #acb057 0 0;ter #acb057 3 1;ter #acb057 1 3;ter #fff 12 0 14 -2;ter #fff 1 4;ter #ffffff 11 0 12 4;")
    set_face(station8.id, "ter #492816 0 0;ter #492816 0 2;ter #492816 1 2;ter #1E1a33 7 3 6 -2;ter #fff 14 0 14 -2;ter #fff 2 4;ter #fff 13 1 20 4;")

    ## Also need to create stations DS-99, DS-101, DS-106
    shared station99 = to_object(npc_spawn(-60000, 200, -63000, "DS-99", "tsn, station", "starbase_civil", "behav_station"))
    set_face(station99.id, "ter #FA01B3 8 1 6  -2;ter #00c3e6 3 0;ter #00c3e6 4 0;ter #00c3e6 4 2;ter #FA01B3 6 2 6 -2;ter #fff 5 5;")
    shared station101 = to_object(npc_spawn(61000, 50, 52000, "DS-101", "tsn, station", "starbase_civil", "behav_station"))
    set_face(station101.id, "ter #ffffff 3 0;ter #ffffff 4 1;ter #ffffff 4 3;ter #FAF0BE 6 3 6 -2;ter #fff 5 5;")
    shared station106 = to_object(npc_spawn(-67000, -200, 37000, "DS-106", "tsn, station", "starbase_civil", "behav_station"))
    set_face(station106.id, "ter #efe6dd 0 0;ter #efe6dd 2 1;ter #efe6dd 2 2;ter #97502d 6 1 6 -2;ter #fff 2 5;ter #fff 13 2 20 4;")

    ## Mine defenses
    ## wrap a minefield around SB-8
    if lethal_value > 0:
        startAngle = random.randrange(130,160)
        angle = random.randrange(110,160)
        endAngle = startAngle + angle
        depth = 1#random.randrange(2,3)
    #        width = random.randrange(int(angle/6), int(angle/3))
        width = int(5 * (lethal_value / 2))
        widthArray = [int(angle / 5.0)]
        inner = random.randrange(1200,1500)
        cluster_spawn_points = scatter_ring(width, depth, 67000, 0, -67000, inner, inner, startAngle, endAngle)
        # Random type, but same for cluster
        for v2 in cluster_spawn_points:
            #keep value between -500 and 500??
    #                v2.y = abs(v2.y) % 500 * (v2.y/abs(v2.y))
            mine_obj = terrain_spawn( v2.x, v2.y + random.randrange(-300,300), v2.z,None, None, "danger_1a", "behav_mine")
            mine_obj.blob.set("damage_done", 5)
            mine_obj.blob.set("blast_radius", 1000)
            mine_obj.engine_object.blink_state = -5
    
    ## wrap a minefield around DS-99
    if lethal_value > 0:
        startAngle = random.randrange(-30,5)
        angle = random.randrange(50,100)
        endAngle = startAngle + angle
        depth = 1#random.randrange(2,3)
    #        width = random.randrange(int(angle/6), int(angle/3))
        width = int(5 * (lethal_value / 2))
        widthArray = [int(angle / 5.0)]
        inner = random.randrange(1200,1500)
        cluster_spawn_points = scatter_ring(width, depth, -60000, 200, -63000, inner, inner, startAngle, endAngle)
        # Random type, but same for cluster
        for v2 in cluster_spawn_points:
            #keep value between -500 and 500??
    #                v2.y = abs(v2.y) % 500 * (v2.y/abs(v2.y))
            mine_obj = terrain_spawn( v2.x, v2.y + random.randrange(-300,300), v2.z,None, None, "danger_1a", "behav_mine")
            mine_obj.blob.set("damage_done", 5)
            mine_obj.blob.set("blast_radius", 1000)
            mine_obj.engine_object.blink_state = -5

    ## wrap a minefield around DS-101
    if lethal_value > 0:
        startAngle = random.randrange(60,90)
        angle = random.randrange(90,140)
        endAngle = startAngle + angle
        depth = 1#random.randrange(2,3)
    #        width = random.randrange(int(angle/6), int(angle/3))
        width = int(5 * (lethal_value / 2))
        widthArray = [int(angle / 5.0)]
        inner = random.randrange(1200,1500)
        cluster_spawn_points = scatter_ring(width, depth, 61000, 50, 52000, inner, inner, startAngle, endAngle)
        # Random type, but same for cluster
        for v2 in cluster_spawn_points:
            #keep value between -500 and 500??
    #                v2.y = abs(v2.y) % 500 * (v2.y/abs(v2.y))
            mine_obj = terrain_spawn( v2.x, v2.y + random.randrange(-300,300), v2.z,None, None, "danger_1a", "behav_mine")
            mine_obj.blob.set("damage_done", 5)
            mine_obj.blob.set("blast_radius", 1000)
            mine_obj.engine_object.blink_state = -5

    ## wrap a minefield around DS-106
    if lethal_value > 0:
        startAngle = random.randrange(-90,-60)
        angle = random.randrange(90,140)
        endAngle = startAngle + angle
        depth = 1#random.randrange(2,3)
    #        width = random.randrange(int(angle/6), int(angle/3))
        width = int(5 * (lethal_value / 2))
        widthArray = [int(angle / 5.0)]
        inner = random.randrange(1200,1500)
        cluster_spawn_points = scatter_ring(width, depth, -67000, -150, 37000, inner, inner, startAngle, endAngle)
        # Random type, but same for cluster
        for v2 in cluster_spawn_points:
            #keep value between -500 and 500??
    #                v2.y = abs(v2.y) % 500 * (v2.y/abs(v2.y))
            mine_obj = terrain_spawn( v2.x, v2.y + random.randrange(-300,300), v2.z,None, None, "danger_1a", "behav_mine")
            mine_obj.blob.set("damage_done", 5)
            mine_obj.blob.set("blast_radius", 1000)
            mine_obj.engine_object.blink_state = -5

    ## Create lifeforms
    shared lf_Akana = lifeform_spawn("Admiral Akana", "ter #acb057 0 0;ter #acb057 3 1;ter #acb057 1 3;ter #fff 12 0 14 -2;ter #fff 1 4;ter #ffffff 11 0 12 4;", "tsn", station8, path="//comms/SB8/Admiral_Akana", title_color="red")
    shared lf_Evans = lifeform_spawn("Commander Evans", "ter #ffffff 0 0;ter #ffffff 1 1;ter #ffffff 2 2;ter #3D2314 8 0 6 -2;ter #fff 12 0 14 -2;ter #fff 0 7;ter #3D2314 9 0 12 4;", "tsn", station8, path="//comms/internal/Commander_Evans", title_color="red")
    shared lf_Richards = lifeform_spawn("Commander Richards", "ter #7C0A02 7 1 6  -2;ter #65371e 3 0;ter #65371e 3 2;ter #65371e 4 2;ter #7C0A02 6 2 6 -2;ter #fff 13 0 14 -2;ter #fff 3 5;", "tsn", station8, path="//comms/internal/Commander_Richards", title_color="red")
    shared lf_Thompson = lifeform_spawn("Commander Thompson", "ter #efe6dd 0 0;ter #efe6dd 0 1;ter #efe6dd 1 3;ter #968b00 6 1 6 -2;ter #fff 12 1 14 -2;ter #fff 2 6;", "tsn", station8, path="//comms/internal/Commander_Thompson", title_color="red")

    ## FRIENDLY NPC WARSHIPS are possible
    if friendly_value >= 1:
        shared Ajax_id = await prefab_spawn(prefab_npc_defender, {"START_X": 71000, "START_Y": 0, "START_Z": -71000, "name": "TSN Ajax", "ship_art": "tsn_dreadnought"})

    if friendly_value >= 2:
        shared Lexington_id = await prefab_spawn(prefab_npc_defender, {"START_X": 64500, "START_Y": 50, "START_Z": 49500, "name": "TSN Lexington", "ship_art": "tsn_heavy_cruiser"})

    if friendly_value >= 3:
        shared Saratoga_id = await prefab_spawn(prefab_npc_defender, {"START_X": -57000, "START_Y": 600, "START_Z": -58000, "name": "TSN Saratoga", "ship_art": "tsn_heavy_cruiser"})

    if friendly_value >= 4:
        shared Patton_id = await prefab_spawn(prefab_npc_defender, {"START_X": -66500, "START_Y": -200, "START_Z": 41000, "name": "TSN Patton", "ship_art": "tsn_heavy_cruiser"})

    ## Create the starting bad guys
    prefab_spawn(prefab_fleet_raider, {"race": "kralien", "fleet_difficulty": DIFFICULTY, "START_X": -37000, "START_Y": 0, "START_Z": -65000})
    prefab_spawn(prefab_fleet_raider, {"race": "kralien", "fleet_difficulty": DIFFICULTY, "START_X": 61000, "START_Y": 0, "START_Z": 30500})
    ## more bad guys at higher DIFFICULTY levels
    if DIFFICULTY >= 6:
        prefab_spawn(prefab_fleet_raider, {"race": "kralien", "fleet_difficulty": DIFFICULTY, "START_X": -49000, "START_Y": 0, "START_Z": -90000})
    if DIFFICULTY >= 8:
        prefab_spawn(prefab_fleet_raider, {"race": "kralien", "fleet_difficulty": DIFFICULTY, "START_X": -74000, "START_Y": 0, "START_Z": 47000})
    if DIFFICULTY >= 10:
        prefab_spawn(prefab_fleet_raider, {"race": "kralien", "fleet_difficulty": DIFFICULTY, "START_X": 70000, "START_Y": 0, "START_Z": 62000})
    if DIFFICULTY >= 11:
        prefab_spawn(prefab_fleet_raider, {"race": "torgoth", "fleet_difficulty": DIFFICULTY, "START_X": 74000, "START_Y": 0, "START_Z": -74000})

    ## cheat by creating "spy asteroids" to watch the approaching Kraliens (name should be None to avoid notice)
    shared spya1 = to_object(terrain_spawn(-50000, 4, -70000,None, "#,asteroid,spyingeye", "plain_asteroid_9", "behav_asteroid"))
    shared spya2 = to_object(terrain_spawn(60500, 4, 43500,None, "#,asteroid,spyingeye", "plain_asteroid_9", "behav_asteroid"))

